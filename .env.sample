# slack application keys for identifying the app
SLACK_SIGNING_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Path on the host to your Firebase service account JSON (mounted into the container)
FIREBASE_CREDENTIALS_PATH=./secrets/firebase-service-account.json

# firebase admin private key path inside the container
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/firebase.json

# Firebase project ID (defaults to slack-in-your-time)
FIREBASE_PROJECT_ID=slack-in-your-time

# slack bot client installation token for a workspace (single-workspace mode; skips Firebase)
# SLACK_BOT_TOKEN=

# Host port to expose the app on (default 3000)
PORT=3000

# node config (production is set by docker-compose)
NODE_ENV=production

# Optional log level override (debug, info, warn, error)
# LOG_LEVEL=info

# Conversion message visibility for single-workspace mode (public or ephemeral)
# CONVERSION_MESSAGE_VISIBILITY=public  # public, ephemeral, or per_member

# Auto-convert channel messages without confirmation (true or false)
# AUTO_CONVERT=false
